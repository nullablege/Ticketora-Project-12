@model CheckoutViewModel

@{
    ViewData["Title"] = "Ticketora | Güvenli Ödeme Geçidi";
}

<!-- Ana Tema Sarmalayıcısı -->
  <div id="mainWrapper" class="w-full min-h-screen bg-mesh-dark text-slate-100 flex flex-col transition-colors duration-300">
    
    <!-- HEADER -->
    <header class="sticky top-0 z-40 glass-nav transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        
        <!-- Logo -->
        <div onclick="window.location.href='/'" class="flex items-center gap-3 cursor-pointer group shrink-0">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/20 group-hover:scale-105 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>
          <span class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent group-hover:from-indigo-300 group-hover:to-purple-300 transition-all duration-300">
            TICKETORA
          </span>
        </div>

        <!-- Actions -->
        <nav class="flex items-center gap-4">


          <!-- Üye Bilgisi -->
          <div id="userNavActions" class="flex items-center gap-4 relative group">
            <div id="navProfileTrigger" class="flex items-center gap-3 cursor-pointer p-1.5 pr-3 rounded-full hover:bg-white/5 transition-all duration-300 border border-transparent hover:border-white/5">
              <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=150&q=80" alt="Avatar" class="w-8 h-8 rounded-full object-cover border border-indigo-500/30">
              <span class="text-sm font-bold text-slate-300 hidden lg:inline">@(User.Identity?.Name ?? "Kullanıcı")</span>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <!-- ANA İÇERİK -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <section class="space-y-8 text-left fade-in-active">
        
        <button onclick="window.location.href='/Events/Detail/@Model.Checkout.EventId'" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-400 hover:text-white transition-colors cursor-pointer group">
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Etkinliğe Geri Dön
        </button>

        <!-- Satın Alma Arayüzü -->
        <div class="grid lg:grid-cols-3 gap-8">
          
          <!-- Sol Sütun: Giriş, Katılımcı ve Ödeme Bilgileri Tek Sayfada -->
          <div class="lg:col-span-2 space-y-6">
            
            <form id="checkoutForm" asp-controller="Booking" asp-action="Checkout" method="post" class="space-y-6">
              @Html.AntiForgeryToken()
              <input type="hidden" name="EventId" value="@Model.Checkout.EventId">
              <input type="hidden" name="UserId" value="@Model.Request.UserId">

              <div asp-validation-summary="ModelOnly" class="text-xs text-red-300"></div>

              <!-- Katılımcı Bilgileri -->
              <div class="space-y-4">
                <h3 class="text-lg font-bold text-white border-b border-white/5 pb-3">1. Katılımcı Bilgileri</h3>
                <div class="p-6 rounded-2xl glass-panel border border-white/5 space-y-4">
                  <div class="grid sm:grid-cols-2 gap-6">
                    <div>
                      <label class="block text-xs font-semibold text-slate-500 mb-1.5 uppercase tracking-wider">Ad Soyad</label>
                      <input type="text" name="PassengerFullName" placeholder="Ege Aytaç" required value="@Model.Request.PassengerFullName"
                             class="w-full px-4 py-3 rounded-xl text-sm glass-input text-slate-200 outline-none">
                    </div>
                    <div>
                      <label class="block text-xs font-semibold text-slate-500 mb-1.5 uppercase tracking-wider">E-posta Adresi</label>
                      <input type="email" name="PassengerEmail" placeholder="ege@ticketora.dev" required value="@Model.Request.PassengerEmail"
                             class="w-full px-4 py-3 rounded-xl text-sm glass-input text-slate-200 outline-none">
                    </div>
                  </div>
                </div>
              </div>

              <!-- Kart ve Ödeme Bilgileri -->
              <div class="space-y-4">
                <h3 class="text-lg font-bold text-white border-b border-white/5 pb-3">2. Güvenli Ödeme Bilgileri</h3>
                
                <div class="p-6 rounded-2xl glass-panel border border-white/5 grid md:grid-cols-5 gap-8 items-center">
                  
                  <!-- Kredi Kartı Görseli (2 Sütun) -->
                  <div class="md:col-span-2 w-full aspect-[1.58/1] rounded-2xl p-6 bg-gradient-to-tr from-slate-900 via-slate-900 to-indigo-950/70 border border-white/10 relative overflow-hidden flex flex-col justify-between shadow-2xl shrink-0">
                    <div class="absolute -right-10 -bottom-10 w-32 h-32 bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
                    <div class="flex justify-between items-start">
                      <div class="flex items-center gap-1.5">
                        <div class="w-6 h-6 rounded-md bg-white/10 flex items-center justify-center">
                          <span class="text-[9px] font-black text-white">TK</span>
                        </div>
                        <span class="text-[9px] font-extrabold tracking-widest text-slate-200">TICKETORA</span>
                      </div>
                      <span class="text-xs text-white/55 font-mono">KREDİ KARTI</span>
                    </div>
                    
                    <div class="my-4">
                      <p class="text-xs text-white/60 tracking-widest uppercase">KART NUMARASI</p>
                      <p id="cardNumVisual" class="text-xs sm:text-sm font-mono font-bold tracking-widest text-white mt-1 whitespace-nowrap overflow-hidden">•••• •••• •••• 4820</p>
                    </div>

                    <div class="flex justify-between items-end">
                      <div>
                        <p class="text-[9px] text-white/60 tracking-wide uppercase">KART SAHİBİ</p>
                        <p id="cardNameVisual" class="text-xs font-bold text-white tracking-wide uppercase mt-0.5">Ege Aytaç</p>
                      </div>
                      <div class="flex gap-3 text-right">
                        <div>
                          <p class="text-[9px] text-white/60 tracking-wide uppercase">SKT</p>
                          <p id="cardExpiryVisual" class="text-xs font-bold text-white font-mono mt-0.5">12/29</p>
                        </div>
                        <div>
                          <p class="text-[9px] text-white/60 tracking-wide uppercase">CVV</p>
                          <p id="cardCvvVisual" class="text-xs font-bold text-white font-mono mt-0.5">•••</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Giriş Kutuları (3 Sütun) -->
                  <div class="md:col-span-3 space-y-4">
                    <div>
                      <label class="block text-xs font-semibold text-slate-500 mb-1.5 uppercase tracking-wider">Kart Üzerindeki İsim</label>
                      <input type="text" id="cardNameInput" placeholder="Ege Aytaç" required
                             class="w-full px-4 py-3 rounded-xl text-sm glass-input text-slate-200 outline-none">
                    </div>
                    <div class="grid grid-cols-4 gap-4">
                      <div class="col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5 uppercase tracking-wider">Kart Numarası</label>
                        <input type="text" id="cardNumInput" placeholder="4000 1234 5678 9010" required maxlength="19"
                               class="w-full px-4 py-3 rounded-xl text-sm glass-input text-slate-200 outline-none">
                      </div>
                      <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5 uppercase tracking-wider">SKT</label>
                        <input type="text" id="cardExpiryInput" placeholder="12/29" required maxlength="5"
                               class="w-full px-4 py-3 rounded-xl text-sm glass-input text-slate-200 outline-none">
                      </div>
                      <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1.5 uppercase tracking-wider">CVV</label>
                        <input type="password" id="cardCvvInput" placeholder="•••" required maxlength="3"
                               class="w-full px-4 py-3 rounded-xl text-sm glass-input text-slate-200 outline-none">
                      </div>
                    </div>
                  </div>
                  
                </div>
              </div>

            </form>
          </div>

          <!-- Sağ Sütun: Rezervasyon Özeti Sidebar -->
          <div>
            <div class="p-6 rounded-2xl glass-panel border border-white/5 space-y-6 sticky top-28">
              <h3 class="text-base font-bold text-white border-b border-white/5 pb-4">Rezervasyon Özeti</h3>
              
              <div class="flex gap-4">
              <img src="@Model.Checkout.EventImage" alt="Thumbnail" class="w-16 h-16 rounded-xl object-cover border border-white/10 shrink-0">
                <div class="text-left">
                  <h4 class="font-bold text-slate-200 text-sm leading-snug line-clamp-2">@Model.Checkout.EventTitle</h4>
                  <p class="text-xs text-slate-500 mt-1">@Model.Checkout.EventDate.ToString("dd MMMM yyyy"), @Model.Checkout.EventLocation</p>
                </div>
              </div>

              <hr class="border-white/5">

              <div class="space-y-3 text-sm">
                <div class="flex justify-between text-slate-400">
                  <span>Bilet Fiyatı</span>
                  <span class="font-bold text-slate-200">$@Model.Checkout.Price.ToString("0.00")</span>
                </div>
                <hr class="border-white/5">
                <div class="flex justify-between items-center">
                  <span class="font-bold text-white">Toplam Tutar</span>
                  <span class="text-xl font-extrabold text-indigo-400">$@Model.Checkout.Price.ToString("0.00")</span>
                </div>
              </div>

              <button type="submit" form="checkoutForm" class="w-full py-4 rounded-xl text-sm font-bold bg-indigo-500 hover:bg-indigo-600 text-white transition-all cursor-pointer shadow-lg shadow-indigo-500/20 text-center block">
                Ödemeyi Tamamla ve Bilet Al
              </button>
            </div>
          </div>

        </div>

      </section>
    </main>

    <!-- FOOTER -->
    <footer class="mt-auto border-t border-white/5 py-8 bg-slate-950/40 text-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-md bg-indigo-500/20 flex items-center justify-center">
            <span class="text-indigo-400 text-[10px] font-black">TK</span>
          </div>
          <span class="text-sm font-bold text-slate-400">Ticketora</span>
        </div>
        <p class="text-xs text-slate-500">© 2026 Ticketora A.Ş. Tüm hakları saklıdır.</p>
      </div>
    </footer>
    
  </div>
