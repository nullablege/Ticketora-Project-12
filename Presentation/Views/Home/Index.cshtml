@model HomeIndexViewModel

@{
    ViewData["Title"] = "Ticketora | Premium Etkinlik Biletleme & Dijital Cüzdan";
    var featuredEvent = Model.FeaturedEvent ?? Model.Events.FirstOrDefault();
}

<div id="mainWrapper" class="w-full min-h-screen bg-mesh-dark text-slate-100 flex flex-col transition-colors duration-300">
    <header class="sticky top-0 z-40 glass-nav transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <div onclick="window.location.href='/'" class="flex items-center gap-3 cursor-pointer group shrink-0">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/20 group-hover:scale-105 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>
          <span class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent group-hover:from-indigo-300 group-hover:to-purple-300 transition-all duration-300">
            TICKETORA
          </span>
        </div>

        <form asp-controller="Home" asp-action="Index" method="get" class="hidden md:flex items-center flex-grow max-w-md mx-8 relative">
          <span class="absolute left-4 text-slate-400 pointer-events-none">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </span>
          <input name="searchText" value="@Model.SearchText" type="text" placeholder="Konser, teknoloji zirveleri, sergiler ara..."
                 class="w-full pl-11 pr-4 py-2.5 rounded-full text-sm glass-input text-slate-200 outline-none">
        </form>

        <nav class="flex items-center gap-4">
          @if (User.Identity?.IsAuthenticated == true)
          {
              <div id="userNavActions" class="flex items-center gap-4 relative group">
                <div id="navProfileTrigger" class="flex items-center gap-3 cursor-pointer p-1.5 pr-3 rounded-full hover:bg-white/5 transition-all duration-300 border border-transparent hover:border-white/5">
                  <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=150&q=80" alt="Avatar" class="w-8 h-8 rounded-full object-cover border border-indigo-500/30">
                  <span class="text-sm font-bold text-slate-300 group-hover:text-white hidden lg:inline">@(User.Identity.Name ?? "Hesabım")</span>
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-white hidden lg:inline transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
                <div id="navProfileDropdown" class="absolute right-0 top-11 w-48 rounded-2xl glass-panel shadow-2xl border border-white/5 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 py-2">
                  <button onclick="window.location.href='/Dashboard'" class="w-full px-4 py-2.5 text-left text-sm text-slate-300 hover:text-white hover:bg-white/5 flex items-center gap-2 cursor-pointer">Profil Paneli</button>
                  <button onclick="window.location.href='/Dashboard/Tickets'" class="w-full px-4 py-2.5 text-left text-sm text-slate-300 hover:text-white hover:bg-white/5 flex items-center gap-2 cursor-pointer">Bilet Geçiş Kartlarım</button>
                  <button onclick="window.location.href='/Dashboard/Settings'" class="w-full px-4 py-2.5 text-left text-sm text-slate-300 hover:text-white hover:bg-white/5 flex items-center gap-2 cursor-pointer">Hesap Ayarları</button>
                  <hr class="border-white/5 my-1.5">
                  <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="w-full px-4 py-2.5 text-left text-sm text-rose-400 hover:text-rose-300 hover:bg-rose-500/10 flex items-center gap-2 cursor-pointer">Çıkış Yap</button>
                  </form>
                </div>
              </div>
          }
          else
          {
              <div id="guestNavActions" class="flex items-center gap-3">
                <button onclick="window.location.href='/Auth'" class="px-5 py-2.5 rounded-full text-sm font-bold text-slate-300 hover:text-white hover:bg-white/5 transition-all cursor-pointer">Giriş Yap</button>
                <button onclick="window.location.href='/Auth'" class="px-5 py-2.5 rounded-full text-sm font-bold bg-indigo-500 hover:bg-indigo-600 transition-colors text-white cursor-pointer shadow-lg shadow-indigo-500/20">Cüzdan Oluştur</button>
              </div>
          }
        </nav>
      </div>
    </header>

    <div class="px-4 py-3 md:hidden border-b border-white/5 glass-panel">
      <form asp-controller="Home" asp-action="Index" method="get" class="relative flex items-center">
        <span class="absolute left-4 text-slate-400 pointer-events-none">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </span>
        <input name="searchText" value="@Model.SearchText" type="text" placeholder="Etkinlikleri ara..."
               class="w-full pl-10 pr-4 py-2 rounded-xl text-xs glass-input text-slate-200 outline-none">
      </form>
    </div>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <section class="space-y-12 fade-in-active">
        @if (featuredEvent != null)
        {
            <div class="relative rounded-3xl overflow-hidden glass-panel border border-white/5 flex flex-col md:flex-row items-center justify-between p-8 md:p-16 gap-8 bg-gradient-to-br from-indigo-950/20 via-slate-900/10 to-purple-950/20 shadow-2xl">
              <div class="absolute -left-10 -top-10 w-48 h-48 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
              <div class="absolute -right-10 -bottom-10 w-48 h-48 bg-purple-500/10 rounded-full blur-3xl pointer-events-none"></div>
              <div class="max-w-xl space-y-6 relative z-10 text-left">
                <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-xs font-bold bg-indigo-500/15 text-indigo-300 border border-indigo-500/30">
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
                  SADECE TICKETORA'DA
                </span>
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-white leading-tight">
                  @featuredEvent.Title
                </h1>
                <p class="text-sm sm:text-base text-slate-400 font-medium max-w-md font-sans">
                  @featuredEvent.Description
                </p>
                <div class="flex flex-wrap items-center gap-4">
                  <button onclick="window.location.href='/Events/Detail/@featuredEvent.Id'" class="px-6 py-3 rounded-full text-sm font-bold bg-white text-slate-950 hover:bg-slate-100 transition-colors shadow-lg cursor-pointer">
                    Öne Çıkan Etkinlik
                  </button>
                  <button onclick="window.location.href='/Auth'" class="px-6 py-3 rounded-full text-sm font-bold bg-white/5 border border-white/10 text-slate-300 hover:text-white hover:bg-white/10 transition-colors cursor-pointer">
                    Cüzdanı Başlat
                  </button>
                </div>
              </div>
              <div class="relative w-full max-w-sm aspect-video md:aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl border border-white/10 shrink-0 transform md:rotate-2 hover:rotate-0 transition-transform duration-500">
                <img src="@featuredEvent.HeroImage" alt="@featuredEvent.Title" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/20 to-transparent flex flex-col justify-end p-6">
                  <span class="text-[10px] font-black text-indigo-400 uppercase tracking-widest mb-1">@featuredEvent.CategoryName</span>
                  <h4 class="font-extrabold text-white text-lg leading-snug">@featuredEvent.Title</h4>
                  <p class="text-xs text-slate-400 mt-1">Giriş Fiyatı: $@featuredEvent.Price.ToString("0.00")'dan itibaren</p>
                </div>
              </div>
            </div>
        }

        <div class="space-y-4 text-left">
          <h2 class="text-xl font-extrabold text-white">Kategorileri Keşfedin</h2>
          <div id="categoryBadges" class="flex gap-3 overflow-x-auto pb-4 no-scrollbar">
            <button onclick="window.location.href='/'" class="flex items-center gap-2 px-5 py-3 rounded-full text-sm font-semibold transition-all duration-300 shrink-0 @(Model.SelectedCategoryId == null ? "bg-gradient-to-r from-indigo-500 to-purple-600 text-white shadow-lg shadow-indigo-500/20" : "bg-white/5 text-slate-400 border border-slate-200/10 hover:border-slate-400/20 hover:text-slate-100") cursor-pointer">
              Tüm Etkinlikler
            </button>
            @foreach (var category in Model.Categories)
            {
                <button onclick="window.location.href='/?categoryId=@category.Id'" class="flex items-center gap-2 px-5 py-3 rounded-full text-sm font-semibold transition-all duration-300 shrink-0 @(Model.SelectedCategoryId == category.Id ? "bg-gradient-to-r from-indigo-500 to-purple-600 text-white shadow-lg shadow-indigo-500/20" : "bg-white/5 text-slate-400 border border-slate-200/10 hover:border-slate-400/20 hover:text-slate-100") cursor-pointer">
                  @category.CategoryName
                </button>
            }
          </div>
        </div>

        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <h2 class="text-2xl font-extrabold text-white text-left">Yaklaşan Deneyimler</h2>
            <span class="text-xs font-semibold text-slate-400">@Model.Events.Count doğrulanmış listeleme</span>
          </div>
          <div id="eventsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var item in Model.Events)
            {
                <div onclick="window.location.href='/Events/Detail/@item.Id'"
                     class="group relative flex flex-col rounded-2xl overflow-hidden glass-panel border border-white/5 hover:border-indigo-500/30 transition-all duration-500 cursor-pointer shadow-lg hover:shadow-2xl hover:shadow-indigo-500/10 transform hover:-translate-y-1.5">
                  <div class="absolute -inset-px bg-gradient-to-r from-indigo-500/0 to-purple-500/0 group-hover:from-indigo-500/10 group-hover:to-purple-500/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
                  <div class="relative w-full aspect-video overflow-hidden">
                    <div class="absolute top-3 left-3 z-10">
                      <span class="px-3 py-1 rounded-full text-xs font-bold bg-slate-900/80 backdrop-blur text-indigo-300 border border-indigo-500/20">@item.CategoryName</span>
                    </div>
                    <img src="@item.HeroImage" alt="@item.Title" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-108" />
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent"></div>
                  </div>
                  <div class="p-6 flex flex-col flex-grow relative z-10 text-left">
                    <div class="flex items-center gap-1.5 text-xs text-indigo-400 font-semibold mb-2">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                      @item.Date.ToString("dd MMMM yyyy")
                    </div>
                    <h3 class="text-lg font-bold text-slate-100 group-hover:text-indigo-300 transition-colors duration-300 line-clamp-1">@item.Title</h3>
                    <p class="text-sm text-slate-400 mt-2 line-clamp-2 flex-grow font-sans">@item.Description</p>
                    <hr class="border-white/5 my-4">
                    <div class="flex items-center justify-between mt-auto">
                      <div class="flex items-center gap-1 text-xs text-slate-400">
                        <svg class="w-4 h-4 shrink-0 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        <span class="truncate max-w-[150px]">@item.Location</span>
                      </div>
                      <div class="text-right">
                        <span class="text-xs text-slate-500 block">Başlangıç</span>
                        <span class="text-base font-extrabold text-indigo-400">$@item.Price.ToString("0.00")</span>
                      </div>
                    </div>
                  </div>
                </div>
            }
          </div>
        </div>
      </section>
    </main>

    <footer class="mt-auto border-t border-white/5 py-8 bg-slate-950/40 text-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-md bg-indigo-500/20 flex items-center justify-center"><span class="text-indigo-400 text-[10px] font-black">TK</span></div>
          <span class="text-sm font-bold text-slate-400">Ticketora</span>
        </div>
        <p class="text-xs text-slate-500">© 2026 Ticketora A.Ş. Tüm hakları saklıdır.</p>
      </div>
    </footer>
</div>
