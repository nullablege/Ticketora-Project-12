@model DashboardIndexViewModel

@{
    ViewData["Title"] = "Ticketora | Genel Bakış";
}

<div id="mainWrapper" class="w-full min-h-screen bg-mesh-dark text-slate-100 flex flex-col transition-colors duration-300">
    <header class="sticky top-0 z-40 glass-nav transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <div onclick="window.location.href='/'" class="flex items-center gap-3 cursor-pointer group shrink-0">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/20 group-hover:scale-105 transition-transform duration-300">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" /></svg>
          </div>
          <span class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">TICKETORA</span>
        </div>
        <nav class="flex items-center gap-4">
          <form asp-controller="Auth" asp-action="Logout" method="post">
            <button type="submit" class="px-4 py-2 rounded-xl bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 transition-all text-xs font-bold cursor-pointer">Çıkış Yap</button>
          </form>
        </nav>
      </div>
    </header>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <section class="space-y-8 text-left fade-in-active">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-white/5 pb-6">
          <div class="flex items-center gap-4">
            <div class="relative">
              <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=150&q=80" alt="Avatar" class="w-16 h-16 rounded-2xl object-cover border-2 border-indigo-500/40">
              <div class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full bg-emerald-500 border-2 border-slate-900 flex items-center justify-center"><span class="w-1.5 h-1.5 rounded-full bg-white"></span></div>
            </div>
            <div>
              <h2 class="text-2xl font-extrabold text-white leading-tight">@Model.FullName</h2>
              <p class="text-sm text-slate-400 mt-0.5">@Model.Email</p>
            </div>
          </div>
          <div class="px-4 py-2.5 rounded-xl bg-white/5 border border-white/5 text-slate-300 text-xs font-semibold">CÜZDAN DURUMU: <span class="text-emerald-400 font-bold">DOĞRULANDI</span></div>
        </div>

        <div class="grid md:grid-cols-4 gap-8">
          <div class="md:col-span-1 space-y-2">
            <button onclick="window.location.href='/Dashboard'" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-semibold transition-all duration-300 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 text-indigo-400 border-l-2 border-indigo-500 w-full text-left cursor-pointer">Genel Bakış</button>
            <button onclick="window.location.href='/Dashboard/Tickets'" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-semibold transition-all duration-300 text-slate-400 hover:bg-white/5 hover:text-slate-200 w-full text-left cursor-pointer">Aktif Biletlerim</button>
            <button onclick="window.location.href='/Dashboard/Settings'" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-semibold transition-all duration-300 text-slate-400 hover:bg-white/5 hover:text-slate-200 w-full text-left cursor-pointer">Ayarlar & Kimlik</button>
          </div>

          <div class="md:col-span-3 space-y-6">
            <div class="grid grid-cols-2 gap-4 text-left">
              <div class="p-6 rounded-2xl glass-panel border border-white/5 bg-gradient-to-tr from-slate-900/50 to-indigo-950/20">
                <span class="text-[10px] uppercase font-bold text-slate-500 tracking-wider block">Aktif Geçiş Kartlarım</span>
                <span class="text-3xl font-extrabold text-indigo-400 block mt-2">@Model.Summary.ActiveTicketCount</span>
              </div>
              <div class="p-6 rounded-2xl glass-panel border border-white/5 bg-gradient-to-tr from-slate-900/50 to-purple-950/20">
                <span class="text-[10px] uppercase font-bold text-slate-500 tracking-wider block">Katıldığım Geçmiş Etkinlikler</span>
                <span class="text-3xl font-extrabold text-purple-400 block mt-2">@Model.Summary.PastEventCount</span>
              </div>
            </div>

            <div class="p-6 rounded-2xl glass-panel border border-white/5 space-y-6 text-left">
              <h3 class="text-base font-bold text-white border-b border-white/5 pb-4 font-sans">Son Aktif Geçiş Kartları</h3>
              <div class="space-y-4">
                @foreach (var ticket in Model.Summary.RecentActiveTickets)
                {
                    <div class="flex items-center justify-between p-4 rounded-xl bg-white/5 border border-white/5 hover:border-white/10 transition-colors gap-4">
                      <div class="flex items-center gap-4 min-w-0">
                        <img src="@ticket.EventImage" alt="@ticket.EventTitle" class="w-12 h-12 rounded-lg object-cover border border-white/10 shrink-0">
                        <div class="min-w-0">
                          <h4 class="font-bold text-slate-200 text-sm leading-snug line-clamp-1">@ticket.EventTitle</h4>
                          <p class="text-xs text-slate-400 mt-1">@ticket.EventDate.ToString("dd MMMM yyyy") • Koltuk: @ticket.Seat</p>
                        </div>
                      </div>
                      <button onclick="window.location.href='/Dashboard/Tickets?ticketId=@ticket.TicketId'" class="px-4 py-2 rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white text-xs font-bold transition-all cursor-pointer shrink-0">Geçiş Kartını Göster</button>
                    </div>
                }
                @if (Model.Summary.RecentActiveTickets.Count == 0)
                {
                    <p class="text-sm text-slate-400">Henüz aktif biletiniz bulunmuyor.</p>
                }
              </div>
            </div>

            <div class="p-6 rounded-2xl glass-panel border border-white/5 space-y-6 text-left">
              <h3 class="text-base font-bold text-white border-b border-white/5 pb-4 font-sans">Geçmiş Etkinlikler</h3>
              <div class="space-y-4">
                @foreach (var item in Model.PastEvents)
                {
                    <div class="flex items-center gap-4 p-4 rounded-xl bg-white/5 border border-white/5">
                      <img src="@item.EventImage" alt="@item.EventTitle" class="w-12 h-12 rounded-lg object-cover border border-white/10 shrink-0">
                      <div>
                        <h4 class="font-bold text-slate-200 text-sm leading-snug">@item.EventTitle</h4>
                        <p class="text-xs text-slate-400 mt-1">@item.EventDate.ToString("dd MMMM yyyy") • @item.EventLocation</p>
                      </div>
                    </div>
                }
                @if (Model.PastEvents.Count == 0)
                {
                    <p class="text-sm text-slate-400">Geçmiş etkinlik kaydınız bulunmuyor.</p>
                }
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="mt-auto border-t border-white/5 py-8 bg-slate-950/40 text-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2"><div class="w-6 h-6 rounded-md bg-indigo-500/20 flex items-center justify-center"><span class="text-indigo-400 text-[10px] font-black">TK</span></div><span class="text-sm font-bold text-slate-400">Ticketora</span></div>
        <p class="text-xs text-slate-500">© 2026 Ticketora A.Ş. Tüm hakları saklıdır.</p>
      </div>
    </footer>
</div>
